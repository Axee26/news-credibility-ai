# ============================================
# NewsCheck — 환경 변수 설정 예시
# 복사하여 .env 파일로 사용하세요
# ============================================

# AI 서버 (FastAPI — Python)
REACT_APP_AI_SERVER_URL=http://localhost:8000

# 메인 서버 (Spring Boot)
REACT_APP_MAIN_SERVER_URL=http://localhost:8080

# 데모 모드 (true: API 없이 Mock 데이터 사용)
REACT_APP_DEMO_MODE=false
